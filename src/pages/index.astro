---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
				margin-top: 3rem;
			}
			.feature-card {
				text-align: left;
			}
			.feature-icon {
				font-size: 2.5rem;
				margin-bottom: 1rem;
				display: block;
			}
			.feature-card h3 {
				font-size: 1.25rem;
				margin-top: 0;
				color: var(--text-primary);
			}
			.trust-badge {
				display: inline-block;
				background: rgba(244, 114, 182, 0.1);
				color: var(--accent);
				padding: 0.25rem 0.75rem;
				border-radius: 100px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1rem;
				border: 1px solid rgba(244, 114, 182, 0.2);
			}
			.cta-section {
				margin-top: 5rem;
				text-align: center;
				padding: 4rem 2rem;
			}
			.about-section {
				margin-top: 4rem;
				display: flex;
				flex-direction: column;
				gap: 2rem;
				align-items: center;
				text-align: center;
			}
			@media (min-width: 768px) {
				.about-section {
					flex-direction: row;
					text-align: left;
					align-items: flex-start;
				}
			}
			.profile-image {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				object-fit: cover;
				border: 3px solid var(--accent);
				box-shadow: 0 4px 20px rgba(244, 114, 182, 0.2);
			}
			.profile-content {
				flex: 1;
			}
			.profile-content h2 {
				margin-top: 0;
				margin-bottom: 0.5rem;
				color: var(--text-primary);
			}
			.profile-content .role {
				color: var(--accent);
				font-size: 0.9rem;
				font-weight: 600;
				display: block;
				margin-bottom: 1rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="trust-badge">看護師・薬剤師の転職成功データ満載</span>
				<h1>あなたに最適な<br><span class="text-gradient">ホワイト求人・エージェント</span>をご提案</h1>
				<p class="lead">
					夜勤なし、土日休み、人間関係良好など。最新のデータとリアルな口コミから、あなたの希望を叶える医療系特化エージェントを厳選比較。
				</p>
				<a href="/blog" class="btn-primary">おすすめエージェント比較を見る →</a>
			</section>

			<section class="features-grid">
				<article class="glass-panel feature-card">
					<span class="feature-icon">🏥</span>
					<h3>非公開の「ホワイト求人」</h3>
					<p>好条件のクリニックや調剤薬局など、一般には公開されない働きやすい職場の求人を多数保有するエージェントのみを紹介します。</p>
				</article>

				<article class="glass-panel feature-card">
					<span class="feature-icon">👩‍⚕️</span>
					<h3>医療現場に精通したサポート</h3>
					<p>特有の人間関係やシフトの悩みなど、医療従事者ならではの事情を理解したプロのキャリアアドバイザーが徹底サポートします。</p>
				</article>

				<article class="glass-panel feature-card">
					<span class="feature-icon">📈</span>
					<h3>年収アップ・待遇改善の実績</h3>
					<p>実際に利用した方の体験談やデータに基づき、確実に年収アップや労働環境の改善が見込めるエージェントを厳選比較しています。</p>
				</article>
			</section>

			<section class="glass-panel about-section">
				<img src="/profile.png" alt="サイト運営者のプロフィール" class="profile-image" />
				<div class="profile-content">
					<h2>運営者について</h2>
					<span class="role">元 夜勤明けに泣いていた看護師</span>
					<p>20代後半、夜勤の連続と人間関係の板挟みで心身ともにボロボロになり、退職を考えては踏みとどまる日々を送っていました。「どこに行っても同じかも…」と半ば諦めかけていた時、医療系に特化した転職エージェントに出会いました。</p>
					<p>担当のアドバイザーさんが親身に話を聞いてくれ、私の希望に合った「完全週休2日・夜勤なし」のホワイトな職場を見つけてくれました。転職後、お給料をキープしたままプライベートの時間が充実し、あの時行動して本当に良かったと思っています。</p>
					<p>自分と同じように過酷な環境で悩む医療従事者の女性に向けて、本当に頼りになるエージェント選びのポイントや、後悔しない転職のコツを発信しています。</p>
				</div>
			</section>

			<section class="glass-panel cta-section">
				<h2>まずは最新のエージェント比較ランキングをチェック</h2>
				<p>当サイトが徹底リサーチして厳選した、女性の働き方改善に強い転職エージェントの比較記事をご覧ください。</p>
				<div style="margin-top: 2rem;">
					<a href="/blog" class="btn-primary" style="background: var(--bg-surface-solid); border: 1px solid var(--accent); color: var(--accent) !important; box-shadow: none;">
						記事一覧へ進む
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
